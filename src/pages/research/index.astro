---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
const posts = (await getCollection("research")).sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
);
---
<Base title="Research" path="/research">
  <section class="hero">
    <h1>Research</h1>
    <p class="tagline">Backtests, walk-forwards, and live signals.</p>
  </section>
  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <div class="post-date">{post.data.date}</div>
        <div class="post-title">
          <a href={`/research/${post.slug}`}>{post.data.title}</a>
        </div>
        <p class="post-summary">{post.data.summary}</p>
      </li>
    ))}
  </ul>
</Base>
